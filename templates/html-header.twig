    <script>
        function sc_plausible404() {
            plausible('404', { props: { path: document.location.pathname } }); 
        }
        function sc_plausibleTimeout() {
            setTimeout(() => {
                if(window.plausible) {
                   sc_plausible404()
                } else {
                  sc_plausibleTimeout()
                }
            }, 1000)
        }
        document.addEventListener('DOMContentLoaded', function () { 
            if(window.plausible) {
               sc_plausible404()
            } else {
                sc_plausibleTimeout()
            }
        });
    </script>
</head>
