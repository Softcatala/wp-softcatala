{% extends "base.twig" %}

{% block content %}

    <!-- .main .wrap-blanc -->
    <main class="main wrap-blanc cd-main-content">
        <!-- .main-header -->
        {% include "contingut-header.twig" %}
        <!--/.main-header -->

        <div class="container-fluid">
            <div class="row">

                <!-- .contingut -->
                <div class="contingut contingut-left col-sm-12 col-md-8">

                    <!-- .formulari-eines  -->
                    <section class="formulari-eines">

                        <form id="sinonims_form">
                            <!-- .btns-diccionari  -->
                            <div class="btns-diccionari row">
                                <div class="col-xs-12">
                                    <p>Introduïu la paraula que voleu cercar i feu clic en el botó de cerca.</p>
                                    <div class="input-group">
                                        <input autofocus type="text" name="sinonims" id="sinonims" class="form-control" placeholder="Introduïu una paraula"/>
                                        <button type="submit" class="input-group-addon bt-basic bt-basic-vermell" id="_action_consulta_sinonims" name="_action_consulta_sinonims">cerca <i id="loading" class="fas fa-spinner fa-pulse" style="display: none;"></i></button>
                                    </div>
                                </div>
                            </div><!--/.btns-diccionari  -->
                        </form>

                        <!-- .diccionari-resultat  -->
                        <div class="diccionari-resultat" id="results" {% if not sinonims_result %}style="display:none"{% endif %}>
                            {% if sinonims_result %}
                                {{ sinonims_result }}
                            {% endif %}
                        </div><!--/.diccionari-resultat  -->

                        {% include "static/index-lletres.twig" with { token: 'les paraules o expressions', url: '/diccionari-de-sinonims/lletra'} only %}

                    </section><!--/.formulari-eines  -->

                    <!-- .contingut-section  -->
                    <section>
                        {{post.content}}
                    </section><!--/.contingut-section  -->
                </div><!--/.contingut -->

                {% include "sidebar_recursos.twig" %}

            </div><!--/.row -->
        </div><!--/.container-fluid -->
    </main><!--/.main .wrap-blanc -->

    <!-- .seccio-vermella -->
    {% include "call-to-action-bottom.twig" %}
    <!--/.seccio-vermella -->

    {% include "contact_form.twig" %}

    {% include "static/sinonims-credits.twig" %}

    {% include "template-avis.twig" %}

{% endblock %}
