{% extends "base.twig" %}

{% block content %}

    <!-- .main .wrap-blanc -->
    <main class="main wrap-blanc cd-main-content">
        <!-- .main-header -->
        {% include "contingut-header.twig" %}
        <!--/.main-header -->

        <div class="container-fluid">
            <div class="row">

                <!-- .contingut -->
                <div class="contingut contingut-left col-sm-12 col-md-8">
                    {% if post.content %}
                    <!-- .contingut-section  -->
                    <section>
                        {{post.content}}
                    </section>
                    <!--/.contingut-section  -->
                    {% endif %}

                    <section class="formulari-eines">

                        <form id="conjugador_form" class="form-horizontal">
                            <!-- .btns-diccionari  -->
                            <div class="btns-diccionari row">
                                <div class="col-xs-12">
                                    <p>Escriviu el verb que voleu cercar i premeu el botó de cerca.</p>
                                    <div class="input-group">
                                        <input type="text" id="source" name="source" required class="form-control typeahead" data-provide="typeahead" autocomplete="off" {% if verb2 %}value="{{ verb }}"{% endif %} placeholder="Introduïu el verb a conjugar">
                                        <button type="button" id="_action_consulta" class="input-group-addon bt-basic bt-basic-vermell">cerca <i style="display: none;" class="fas fa-spinner fa-pulse" id="loading"></i></button>
                                        <input id="infinitiu" type="hidden" name="infinitiu" value="">
                                        <input id="verburl" type="hidden" name="verburl" value="">
                                    </div>
                                </div>
                            </div><!--/.btns-diccionari  -->
                            <header>
                                <div class="filtres row">
                                    <div class="col-sm-5">
                                        <i id="loading" class="fas fa-spinner fa-pulse" style="display: none;"></i>
                                    </div>
                            </div>
                            </header>

                            <input type="submit" style="display:none;" />
                        </form>

                    </section>


                    <section id="resultats-conjugador" {% if not cerca_result %}style="display:none"{% endif %}>
                        {% if cerca_result %}
                            {{ cerca_result }}
                        {% endif %}
                    </section><!--/.resultats conjugador  -->

                    <section class="formulari-eines">
                        {% include "static/index-lletres.twig" with { token: 'els verbs', url: '/conjugador-de-verbs/lletra' } only  %}
                    </section>

                </div><!--/.contingut -->

                {% include "sidebar_recursos.twig" %}

            </div><!--/.row -->
        </div><!--/.container-fluid -->
    </main><!--/.main .wrap-blanc -->

    <!-- .seccio-vermella -->
    {% include "call-to-action-bottom.twig" %}
    <!--/.seccio-vermella -->

    {% include "contact_form.twig" %}

    {% include "static/conjugador-credits.twig" %}

    {% include "template-avis.twig" %}

{% endblock %}
